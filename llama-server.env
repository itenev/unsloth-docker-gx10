# llama-server configuration
# Edit this file to change model, port, or inference settings.
# Restart the service after changes: sudo systemctl restart llama-server

# ── Model ─────────────────────────────────────────────────────────────────────
MODEL=/home/itenev/models/.cache/huggingface/hub/models--unsloth--Qwen3.6-27B-GGUF/snapshots/82d411acf4a06cfb8d9b073a5211bf410bfc29bf/Qwen3.6-27B-UD-Q4_K_XL.gguf

# ── Network ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080

# ── GPU ───────────────────────────────────────────────────────────────────────
# -1 = offload all layers to GPU (safe on GX10 unified 124GB pool)
N_GPU_LAYERS=-1

# ── Context ───────────────────────────────────────────────────────────────────
CONTEXT_SIZE=262144

# ── Parallelism ───────────────────────────────────────────────────────────────
# Number of parallel inference slots (concurrent requests)
PARALLEL=4

# ── Flash attention ───────────────────────────────────────────────────────────
# Accepted values: on, off, auto
FLASH_ATTN=auto
